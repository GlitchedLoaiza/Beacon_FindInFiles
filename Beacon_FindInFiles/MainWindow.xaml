<Window
    x:Class="Beacon.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Beacon: Find in Files"
    WindowState="Maximized"
    MinWidth="1000"
    MinHeight="700"
    Icon="/beacon_no_bg.png">

    <!-- ========================= -->
    <!-- THEME RESOURCES           -->
    <!-- ========================= -->
    <Window.Resources>

        <!-- Light Theme Colors -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="White"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#E6E6E6"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#202020"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="#888888"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0066CC"/>
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="White"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#FAFAFA"/>

        <!-- Modern Button Style -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- Modern GroupBox Style -->
        <Style TargetType="GroupBox">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- Modern ListBox Style -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        </Style>

        <!-- Modern RichTextBox Style -->
        <Style TargetType="RichTextBox">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        </Style>

    </Window.Resources>

    <!-- ========================= -->
    <!-- ROOT GRID                 -->
    <!-- ========================= -->
    <Grid Background="{DynamicResource WindowBackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- TOP BAR                  -->
        <!-- ========================= -->
        <Grid Grid.Row="0" Margin="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- PATH -->
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Path:"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox Grid.Row="0"
                     Grid.Column="1"
                     x:Name="Path_txt"
                     Margin="0,0,12,0"
                     IsEnabled="False"/>

            <StackPanel Grid.Row="0"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Margin="0,0,8,0">

                <Button x:Name="BrowseFolder_btn"
                        Content="📁 Folder"
                        Width="90"
                        Margin="0,0,6,0"
                        ToolTip="Select a folder to scan recursively"/>

                <Button x:Name="BrowseZip_btn"
                        Content="📦 Archive"
                        Width="100"
                        ToolTip="Select an archive to scan (ZIP, 7Z, RAR, TAR, GZ, etc.)"/>

            </StackPanel>

            <Button Grid.Row="0"
                    Grid.Column="3"
                    x:Name="Scan_btn"
                    Content="Scan (Enter)"
                    IsEnabled="False"/>

            <!-- SEARCH -->
            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Search for:"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="0,10,8,0"/>

            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     x:Name="Search_txt"
                     Margin="0,10,12,0"/>

            <StackPanel Grid.Row="1"
                        Grid.Column="2"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                <CheckBox x:Name="CaseSensitive_chk"
                          Content="Case sensitive"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>

                <!-- Theme Toggle Button -->
                <Button x:Name="ThemeToggle_btn"
                        Content="🌙"
                        Width="36"
                        MinWidth="36"
                        FontSize="16"
                        Padding="0"
                        Margin="0,0,12,0"
                        ToolTip="Toggle Light/Dark theme"/>

                <Button x:Name="Reset_btn"
                        Content="Reset (Ctrl+R)"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <!-- ========================= -->
        <!-- MAIN CONTENT              -->
        <!-- ========================= -->
        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- MATCHED FILES -->
            <GroupBox Grid.Row="0"
                      Grid.Column="0"
                      Header="Matched Files"
                      Margin="8">

                <ListBox x:Name="Results_lst"
                         FontFamily="Consolas"
                         FontSize="13"/>
            </GroupBox>

            <GridSplitter Grid.Row="0"
                          Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#C0C0C0"/>

            <!-- PREVIEW -->
            <Grid Grid.Row="0"
                  Grid.Column="2"
                  Margin="8">

                <!-- TEXT PREVIEW -->
                <GroupBox Header="Preview (Text)"
                          x:Name="TextPreview_grp">

                    <RichTextBox x:Name="TextPreview_rtb"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>

                </GroupBox>

                <!-- EVENT PREVIEW (CORRECTED) -->
                <GroupBox Header="Preview (Event)"
                          x:Name="EventPreview_grp"
                          Visibility="Collapsed">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Scrollable event content -->
                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                            <StackPanel Margin="12">

                                <TextBlock x:Name="EventLevel_txt"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#C00000"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="EventId_txt"
                                           FontWeight="SemiBold"/>

                                <TextBlock x:Name="EventProvider_txt"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>

                                <TextBlock x:Name="EventTime_txt"
                                           Margin="0,4,0,12"/>

                                <Separator/>

                                <TextBlock x:Name="EventMessage_txt"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- FIXED event counter -->
                        <Border Grid.Row="1"
                                Padding="8,6"
                                Background="#F0F0F0"
                                BorderBrush="#D0D0D0"
                                BorderThickness="0,1,0,0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="EventMatchCounter_lbl"
                                           Grid.Column="0"
                                           FontWeight="SemiBold"
                                           Text="0 match(es) in this event"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"/>

                                <TextBlock x:Name="EventCounter_lbl"
                                           Grid.Column="1"
                                           FontWeight="SemiBold"
                                           Text="Viewing 0 of 0 event(s)"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </GroupBox>

                <!-- HAR REQUEST PREVIEW -->
                <GroupBox Header="Preview (HAR Request)"
                          x:Name="HarPreview_grp"
                          Visibility="Collapsed">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Scrollable HAR content -->
                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                            <StackPanel Margin="12">

                                <!-- Request Method and URL -->
                                <TextBlock x:Name="HarMethod_txt"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#0066CC"
                                           Margin="0,0,0,4"/>

                                <TextBlock x:Name="HarUrl_txt"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="#333"
                                           Margin="0,0,0,8"
                                           Background="#F9F9F9"
                                           Padding="4"/>

                                <!-- Status and Timing -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="Status:" 
                                               FontWeight="SemiBold"
                                               Margin="0,0,8,0"/>
                                    <TextBlock x:Name="HarStatus_txt" 
                                               Grid.Column="1"
                                               Margin="0,0,16,0"/>

                                    <TextBlock Grid.Column="2" 
                                               Text="Time:" 
                                               FontWeight="SemiBold"
                                               Margin="0,0,8,0"/>
                                    <TextBlock x:Name="HarDuration_txt" 
                                               Grid.Column="3"/>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" 
                                               Text="Started:" 
                                               FontWeight="SemiBold"
                                               Margin="0,0,8,0"/>
                                    <TextBlock x:Name="HarTime_txt" 
                                               Grid.Column="1"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Margin="0,0,16,0"/>

                                    <TextBlock Grid.Column="2" 
                                               Text="Server IP:" 
                                               FontWeight="SemiBold"
                                               Margin="0,0,8,0"/>
                                    <TextBlock x:Name="HarServerIp_txt" 
                                               Grid.Column="3"
                                               FontFamily="Consolas"
                                               FontSize="11"/>
                                </Grid>

                                <Separator Margin="0,0,0,8"/>

                                <!-- Request Headers -->
                                <TextBlock Text="Request Headers"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="0,0,0,4"/>
                                <ScrollViewer MaxHeight="150"
                                              VerticalScrollBarVisibility="Auto"
                                              Margin="0,0,0,12">
                                    <TextBlock x:Name="HarRequestHeaders_txt"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Background="{DynamicResource CodeBackgroundBrush}"
                                               Padding="8"/>
                                </ScrollViewer>

                                <!-- Request Body -->
                                <TextBlock Text="Request Payload (Body)"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="0,0,0,4"/>
                                <ScrollViewer MaxHeight="200"
                                              VerticalScrollBarVisibility="Auto"
                                              Margin="0,0,0,12">
                                    <TextBlock x:Name="HarRequestBody_txt"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Background="{DynamicResource CodeBackgroundBrush}"
                                               Padding="8"/>
                                </ScrollViewer>

                                <Separator Margin="0,0,0,8"/>

                                <!-- Response Headers -->
                                <TextBlock Text="Response Headers"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="0,0,0,4"/>
                                <ScrollViewer MaxHeight="150"
                                              VerticalScrollBarVisibility="Auto"
                                              Margin="0,0,0,12">
                                    <TextBlock x:Name="HarResponseHeaders_txt"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Background="{DynamicResource CodeBackgroundBrush}"
                                               Padding="8"/>
                                </ScrollViewer>

                                <!-- Response Body -->
                                <TextBlock Text="Response Payload (Body)"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="0,0,0,4"/>
                                <ScrollViewer MaxHeight="300"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="HarResponseBody_txt"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Background="{DynamicResource CodeBackgroundBrush}"
                                               Padding="8"/>
                                </ScrollViewer>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- HAR request counter -->
                        <Border Grid.Row="1"
                                Padding="8,6"
                                Background="#F0F0F0"
                                BorderBrush="#D0D0D0"
                                BorderThickness="0,1,0,0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="HarMatchCounter_lbl"
                                           Grid.Column="0"
                                           FontWeight="SemiBold"
                                           Text="0 match(es) in this request"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"/>

                                <TextBlock x:Name="HarCounter_lbl"
                                           Grid.Column="1"
                                           FontWeight="SemiBold"
                                           Text="Viewing 0 of 0 request(s)"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </GroupBox>

                <!-- WEB PREVIEW (HTML/XML) -->
                <GroupBox Header="Preview (HTML/XML)"
                          x:Name="WebPreview_grp"
                          Visibility="Collapsed">

                    <wv2:WebView2 x:Name="WebPreview_wv2"/>

                </GroupBox>
            </Grid>


            <!-- ========================= -->
            <!-- BOTTOM COMMAND BAR        -->
            <!-- ========================= -->
            <Grid Grid.Row="1"
      Grid.Column="0"
      Grid.ColumnSpan="3"
      Margin="8,0,8,8">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Button Grid.Column="0"
            x:Name="NextFile_btn"
            Content="Next File (Ctrl+↓)"
            Visibility="Collapsed"/>

                <!-- RIGHT SIDE -->
                <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right">

                    <Button x:Name="FindPreviousEvent_btn"
                Content="Previous Event (Shift+F3)"
                Visibility="Collapsed"
                Margin="0,0,8,0"/>

                    <Button x:Name="FindNext_btn"
                Content="Find Next (F3)"
                Visibility="Collapsed"
                Margin="0,0,8,0"/>

                    <Button x:Name="FindNextEvent_btn"
                Content="Find Next Event (F3)"
                Visibility="Collapsed"/>

                    <Button x:Name="FindPreviousHarRequest_btn"
                Content="Previous Request (Shift+F3)"
                Visibility="Collapsed"
                Margin="0,0,8,0"/>

                    <Button x:Name="FindNextHarRequest_btn"
                Content="Find Next Request (F3)"
                Visibility="Collapsed"/>

                </StackPanel>
            </Grid>
        </Grid>

        <!-- ========================= -->
        <!-- STATUS BAR (FIXED)        -->
        <!-- ========================= -->
        <Border Grid.Row="2"
                Background="{DynamicResource StatusBarBackgroundBrush}"
                Padding="8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="Status_lbl"
                           Grid.Column="0"
                           Text="Status: Ready"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <TextBlock x:Name="TimeElapsed_lbl"
                           Grid.Column="1"
                           Text="Time Elapsed: 00:00:00"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           Visibility="Collapsed"/>

                <TextBlock x:Name="CurrentFile_lbl"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="60,0,12,0"/>

                <ProgressBar x:Name="ScanProgress_pb"
                             Grid.Column="3"
                             Width="180"
                             Height="16"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             IsIndeterminate="False"
                             Visibility="Collapsed"/>

                <!-- Discrete Feedback Link -->
                <TextBlock Grid.Column="4"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0">
                    <Hyperlink x:Name="Feedback_lnk"
                               NavigateUri="https://github.com/GlitchedLoaiza/Beacon_FindInFiles/discussions"
                               RequestNavigate="Feedback_lnk_RequestNavigate"
                               FontSize="11"
                               TextDecorations="None">
                        <Hyperlink.Style>
                            <Style TargetType="Hyperlink">
                                <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Hyperlink.Style>
                        💬 Feedback
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

    </Grid>
</Window>